generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CHEQUING
  SAVINGS
  TFSA
  RRSP
  FHSA
  CREDIT
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_OUT
  TRANSFER_IN
}

enum RecurringTransactionType {
  DEPOSIT
  WITHDRAWAL
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model Account {
  id          String      @id @default(cuid())
  userId      String
  ownerName   String
  nickname    String?
  accountType AccountType @default(CHEQUING)
  balance     Float       @default(0)
  frozen      Boolean     @default(false)
  createdAt   DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(3)

  sentTransactions     Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
  recurringTransactions RecurringTransaction[]
}

model Profile {
  userId     String   @id
  firstName  String
  lastName   String
  username   String   @unique
  email      String
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)
}

model CategoryBudget {
  id           String   @id
  userId       String
  category     String
  monthlyLimit Float
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)

  @@unique([userId, category])
}

model Transaction {
  id           String          @id @default(cuid())
  type         TransactionType
  amount       Float
  balanceAfter Float
  transferGroupId String?
  category     String?
  description  String?
  effectiveAt  DateTime        @default(now()) @db.Timestamptz(3)
  createdAt    DateTime        @default(now()) @db.Timestamptz(3)

  fromAccountId String?
  fromAccount   Account? @relation("SentTransactions", fields: [fromAccountId], references: [id])

  toAccountId String?
  toAccount   Account? @relation("ReceivedTransactions", fields: [toAccountId], references: [id])
}

model RecurringTransaction {
  id          String                   @id @default(cuid())
  userId      String
  accountId   String
  type        RecurringTransactionType
  amount      Float
  category    String?
  description String?
  frequency   RecurringFrequency
  startDate   DateTime                 @db.Timestamptz(3)
  endDate     DateTime?                @db.Timestamptz(3)
  nextRunAt   DateTime                 @db.Timestamptz(3)
  lastRunAt   DateTime?                @db.Timestamptz(3)
  active      Boolean                  @default(true)
  createdAt   DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime                 @updatedAt @db.Timestamptz(3)

  account     Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, active, nextRunAt])
}
